{
  "_comment": "Format registry for broker meter data normaliser. Add a new entry here to support a new broker format — no Python code changes needed.",
  "formats": [
    {
      "id": "format_1",
      "description": "Excel with ReadingDateTime serial and E/B register columns",
      "file_type": "xlsx",
      "skip_rows": 0,
      "fingerprint_columns": ["ReadingDateTime", "E (Usage kWh)", "B (Generation kWh)"],
      "nmi_col": "NMI",
      "nmi_strip_after": "-",
      "datetime_cols": ["ReadingDateTime"],
      "datetime_type": "auto",
      "datetime_is_end": false,
      "consumption_col": "E (Usage kWh)",
      "export_col": "B (Generation kWh)",
      "interval_min": 30
    },
    {
      "id": "format_2",
      "description": "Engauge Excel export — header on row 3, Interval column is END timestamp, no export register",
