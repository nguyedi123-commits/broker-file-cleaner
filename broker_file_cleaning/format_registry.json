      "skip_rows": 2,
      "fingerprint_columns": ["NMI", "Interval", "kWh", "Power Factor", "Substitution Data"],
      "nmi_col": "NMI",
      "datetime_cols": ["Interval"],
      "datetime_type": "auto",
      "datetime_is_end": true,
      "consumption_col": "kWh",
      "export_col": null,
      "interval_min": 30
    },
